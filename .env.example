# Database
DATABASE_URL=postgresql://user:password@localhost:5432/incidentally

# Server
PORT=3001
NODE_ENV=development
SESSION_SECRET=change-this-in-production
# SESSION_STORE=memory    # memory (default) | pg (requires connect-pg-simple)

# AWS / Redshift (for Pro data integration)
AWS_REGION=us-west-2
AWS_PROFILE=your-sso-profile
REDSHIFT_CLUSTER_ID=instawork-dw
REDSHIFT_DATABASE=instawork
REDSHIFT_DB_USER=engineering

# File Storage (optional -- defaults to local disk in ./uploads)
# FILE_STORAGE=s3
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_PREFIX=incidentally   # optional; key prefix for document keys (default: incidentally)
